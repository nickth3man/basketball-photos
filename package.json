{
  "name": "basketball-photos",
  "version": "1.0.0",
  "description": "NBA Photo Analyzer & Discovery System",
  "private": true,
  "scripts": {
    "lint": "python -m ruff check .",
    "format:check": "python -m ruff format --check .",
    "format": "python -m ruff format .",
    "test": "python -m pytest",
    "test:verbose": "python -m pytest -v",
    "test:coverage": "python -m pytest --cov=src --cov-report=term-missing",
    "quality": "python -m ruff check . && python -m ruff format --check . && python -m pytest",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0"
  },
  "packageManager": "npm@11.6.2"
}
